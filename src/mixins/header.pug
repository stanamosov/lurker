mixin header()
  - var viewQuery = 'view=' + (query && query.view ? query.view : 'compact')
  div.header
    div.header-item
      a(href=`/?${viewQuery}`) home
    div.header-item
      a(href=`/r/all?${viewQuery}`) all
    div.header-item
      a(href=`/search?${viewQuery}`) search
    div.header-item
      a(href=`/subs?${viewQuery}`) subs
